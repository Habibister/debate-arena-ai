# Database
# Local PostgreSQL:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/debatearena_ai?schema=public"
#
# Neon or Supabase PostgreSQL:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"
#
# Keep the connection string server-only. Never expose it with NEXT_PUBLIC_.

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
# Generate a strong secret locally:
# openssl rand -base64 32

# ── AI providers ──────────────────────────────────────────────────────────────
# DebateArena AI does not require paid OpenAI. It tries free/cheap cloud providers
# first and only uses the deterministic local fallback if every provider fails.
#
# Priority (AI_PROVIDER=auto): Gemini -> Groq -> OpenRouter (:free) -> OpenAI.
# Set AI_PROVIDER to a specific provider (gemini|groq|openrouter|openai) to pin it.
AI_PROVIDER="auto"

# Cost guard. "free_only" (default) never calls the paid OpenAI provider, even if a
# key is set. Use "allow_paid" to let OpenAI participate.
AI_COST_MODE="free_only"

# Google Gemini (free tier) — recommended. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# Groq (fast, free tier). Get a key at https://console.groq.com/keys
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

# OpenRouter (has :free models). Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="meta-llama/llama-3.3-70b-instruct:free"

# OpenAI (optional, paid). Only used when AI_COST_MODE="allow_paid".
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Password reset email (Resend). APP_URL builds the reset link (falls back to NEXTAUTH_URL). Without
# RESEND_API_KEY + EMAIL_FROM, reset links are logged to the server console in development; in
# production with no provider, the request still returns the generic success message.
APP_URL="http://localhost:3000"
EMAIL_FROM="DebateArena AI <no-reply@yourdomain.com>"
RESEND_API_KEY=""

# Profile picture storage (UploadThing). Required on Vercel — the serverless filesystem is read-only,
# so avatars must go to external storage. Without it, photo upload shows a graceful "not configured"
# message and accounts can still be created. Get a token at https://uploadthing.com/dashboard
UPLOADTHING_TOKEN=""

# Demo seed users
SEED_ADMIN_EMAIL="admin@debatearena.ai"
SEED_ADMIN_PASSWORD="password123"
SEED_COACH_EMAIL="coach@debatearena.ai"
SEED_COACH_PASSWORD="password123"
SEED_STUDENT_EMAIL="student@debatearena.ai"
SEED_STUDENT_PASSWORD="password123"
