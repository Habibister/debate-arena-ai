generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  COACH
  ADMIN
}

enum Organization {
  DEBATE
  MODEL_UN
  DECA
  HOSA
  MOCK_TRIAL
  PUBLIC_SPEAKING
}

enum Level {
  BEGINNER
  INTERMEDIATE
  ELITE
}

enum DebateMode {
  AI
  REAL_STUDENT
}

enum DebateFormat {
  PARLIAMENTARY
  QUICK_1V1
  PUBLIC_FORUM
  PRACTICE_REBUTTAL
  CUSTOM
}

enum DebateSide {
  GOVERNMENT
  OPPOSITION
  FOR
  AGAINST
}

enum DebateStatus {
  SETUP
  ACTIVE
  JUDGED
  ARCHIVED
}

enum PracticeMode {
  DEBATE
  ROLEPLAY
  TEST
  LESSON
}

enum MessageRole {
  AFFIRMATIVE
  NEGATIVE
  MODERATOR
  JUDGE
  SYSTEM
}

enum TestStatus {
  GENERATED
  IN_PROGRESS
  COMPLETED
}

enum SkillTrack {
  DEBATE
  MODEL_UN
  DECA
  HOSA
  MOCK_TRIAL
  PUBLIC_SPEAKING
}

enum LessonType {
  LESSON
  EXAMPLES
  GUIDED_PRACTICE
  INDEPENDENT_PRACTICE
  MASTERY_QUIZ
}

enum Rank {
  BRONZE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
  MASTER
}

enum AchievementType {
  XP_STREAK
  DEBATE_WIN
  MASTERY_TEST
  COACH_ASSIGNED
  READINESS
}

enum MasteryLevel {
  NOT_STARTED
  LEARNING
  PRACTICING
  MASTERED
}

enum PracticeAttemptStatus {
  IN_PROGRESS
  COMPLETED
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  passwordHash   String?
  resetPasswordTokenHash String?
  resetPasswordExpires   DateTime?
  username       String?   @unique
  displayName    String?
  avatarUrl      String?
  bio            String?   @db.Text
  schoolOrClub   String?
  preferredOrganization Organization?
  role           Role      @default(STUDENT)
  organization   Organization?
  level          Level     @default(BEGINNER)
  ageGroup       String?
  xp             Int       @default(0)
  streak         Int       @default(0)
  wins           Int       @default(0)
  rank           Rank      @default(BRONZE)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  coachProfile      Coach?
  teamMemberships   TeamMember[]
  createdDebates    Debate[]           @relation("CreatedDebates")
  studentDebates    Debate[]           @relation("StudentDebates")
  opponentDebates   Debate[]           @relation("OpponentDebates")
  debateMessages    DebateMessage[]
  practiceTests     PracticeTest[]
  practiceAnswers   PracticeAnswer[]
  achievements      Achievement[]
  xpLogs            XPLog[]
  speakingSnapshots SpeakingSkillSnapshot[]
  lessonAssignments LessonAssignment[] @relation("AssignedTo")
  assignedLessons   LessonAssignment[] @relation("AssignedBy")
  masteryProgresses MasteryProgress[]
  practiceAttempts  PracticeAttempt[]
  questionAttempts  QuestionAttempt[]
}

model Debate {
  id             String       @id @default(cuid())
  organization   Organization
  eventType      String       @default("PARLIAMENTARY_DEBATE")
  practiceMode   PracticeMode @default(DEBATE)
  format         DebateFormat @default(PARLIAMENTARY)
  rubricId       String?
  level          Level
  topic          String
  mode           DebateMode
  status         DebateStatus @default(SETUP)
  roundsMinimum  Int          @default(3)
  studentSide    DebateSide   @default(GOVERNMENT)
  opponentSide   DebateSide   @default(OPPOSITION)
  turnTimeSeconds Int         @default(420)
  prepTimeSeconds Int         @default(300)
  graceTimeSeconds Int        @default(30)
  formatConfig   Json?
  aiPersona      String?
  createdById    String
  studentId      String?
  opponentUserId String?
  logicScore     Int?
  evidenceScore  Int?
  rebuttalScore  Int?
  persuasionScore Int?
  clarityScore   Int?
  communicationScore Int?
  overallScore   Int?
  strengths      String[]     @default([])
  weaknesses     String[]     @default([])
  recommendations String[]    @default([])
  readiness      Json?
  judgeReport    Json?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  createdBy    User             @relation("CreatedDebates", fields: [createdById], references: [id], onDelete: Cascade)
  student      User?            @relation("StudentDebates", fields: [studentId], references: [id], onDelete: SetNull)
  opponentUser User?            @relation("OpponentDebates", fields: [opponentUserId], references: [id], onDelete: SetNull)
  rubric       Rubric?          @relation(fields: [rubricId], references: [id], onDelete: SetNull)
  messages     DebateMessage[]

  @@index([organization, eventType, level, status])
  @@index([studentId])
  @@index([opponentUserId])
  @@index([rubricId])
}

model DebateMessage {
  id        String      @id @default(cuid())
  debateId  String
  authorId  String?
  role      MessageRole
  round     Int
  content   String      @db.Text
  createdAt DateTime    @default(now())

  debate Debate @relation(fields: [debateId], references: [id], onDelete: Cascade)
  author User?  @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([debateId, round])
}

model Skill {
  id          String       @id @default(cuid())
  track       SkillTrack
  organization Organization
  name        String
  slug        String       @unique
  description String
  order       Int          @default(0)
  masteryWeights Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  lessons Lesson[]
  masteryProgresses MasteryProgress[]
  practiceAttempts  PracticeAttempt[]
  questionAttempts  QuestionAttempt[]

  @@index([organization, order])
}

model Lesson {
  id               String       @id @default(cuid())
  skillId          String
  title            String
  slug             String       @unique
  type             LessonType
  summary          String
  content          Json
  xpReward         Int          @default(10)
  estimatedMinutes Int          @default(8)
  order            Int          @default(0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  skill       Skill              @relation(fields: [skillId], references: [id], onDelete: Cascade)
  assignments LessonAssignment[]
  practiceAttempts PracticeAttempt[]
  questionAttempts QuestionAttempt[]
  recommendedFor   MasteryProgress[]

  @@index([skillId, order])
}

model MasteryProgress {
  id                String       @id @default(cuid())
  userId            String
  skillId           String
  masteryLevel      MasteryLevel @default(NOT_STARTED)
  masteryPercent    Int          @default(0)
  xpEarned          Int          @default(0)
  correctCount      Int          @default(0)
  incorrectCount    Int          @default(0)
  weakSkillCount    Int          @default(0)
  recommendedLessonId String?
  lastPracticedAt   DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill             Skill        @relation(fields: [skillId], references: [id], onDelete: Cascade)
  recommendedLesson Lesson?      @relation(fields: [recommendedLessonId], references: [id], onDelete: SetNull)

  @@unique([userId, skillId])
  @@index([userId, masteryLevel])
  @@index([skillId])
  @@index([recommendedLessonId])
}

model PracticeAttempt {
  id              String                @id @default(cuid())
  userId          String
  skillId         String
  lessonId        String?
  status          PracticeAttemptStatus @default(IN_PROGRESS)
  score           Int?
  correctCount    Int                   @default(0)
  totalQuestions  Int                   @default(0)
  weakSkills      String[]              @default([])
  masteredConcepts String[]             @default([])
  reviewConcepts  String[]              @default([])
  startedAt       DateTime              @default(now())
  completedAt     DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill           Skill                 @relation(fields: [skillId], references: [id], onDelete: Cascade)
  lesson          Lesson?               @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  questionAttempts QuestionAttempt[]

  @@index([userId, createdAt])
  @@index([skillId, status])
  @@index([lessonId])
}

model QuestionAttempt {
  id              String   @id @default(cuid())
  attemptId       String
  userId          String
  skillId         String
  lessonId        String?
  prompt          String   @db.Text
  selectedAnswer  String
  correctAnswer   String
  isCorrect       Boolean
  explanation     String   @db.Text
  skillTag        String
  retryPrompt     String?  @db.Text
  createdAt       DateTime @default(now())

  attempt         PracticeAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill           Skill           @relation(fields: [skillId], references: [id], onDelete: Cascade)
  lesson          Lesson?         @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  @@index([attemptId])
  @@index([userId, createdAt])
  @@index([skillId, isCorrect])
  @@index([lessonId])
}

model PracticeTest {
  id             String       @id @default(cuid())
  userId         String
  organization   Organization
  eventType      String       @default("GENERAL_TEST")
  eventCluster   String?
  difficulty     Level
  questionCount  Int
  status         TestStatus    @default(GENERATED)
  score          Int?
  weakAreas      String[]      @default([])
  recommendations Json?
  createdAt      DateTime     @default(now())
  completedAt    DateTime?

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions PracticeQuestion[]
  answers   PracticeAnswer[]

  @@index([userId, createdAt])
  @@index([organization, eventType, difficulty])
}

model PracticeQuestion {
  id            String       @id @default(cuid())
  testId        String
  question      String       @db.Text
  choices       Json
  correctAnswer String
  explanation   String       @db.Text
  skillTag      String
  difficulty    Level
  createdAt     DateTime     @default(now())

  test    PracticeTest    @relation(fields: [testId], references: [id], onDelete: Cascade)
  answers PracticeAnswer[]

  @@index([testId])
  @@index([skillTag])
}

model PracticeAnswer {
  id               String   @id @default(cuid())
  testId           String
  questionId       String
  userId           String
  selectedAnswer   String
  isCorrect        Boolean
  explanationShown Boolean  @default(false)
  createdAt        DateTime @default(now())

  test     PracticeTest     @relation(fields: [testId], references: [id], onDelete: Cascade)
  question PracticeQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([questionId, userId])
  @@index([testId, userId])
}

model Coach {
  id        String   @id @default(cuid())
  userId    String   @unique
  title     String?
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  teams Team[]
}

model Team {
  id           String       @id @default(cuid())
  name         String
  joinCode     String?      @unique
  schoolOrClub String?
  organization Organization
  coachId      String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  coach  Coach        @relation(fields: [coachId], references: [id], onDelete: Cascade)
  members TeamMember[]

  @@unique([coachId, name])
  @@index([organization])
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  role      Role     @default(STUDENT)
  joinedAt  DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
}

model LessonAssignment {
  id           String    @id @default(cuid())
  lessonId     String
  studentId    String
  assignedById String
  dueAt        DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  lesson     Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  student    User   @relation("AssignedTo", fields: [studentId], references: [id], onDelete: Cascade)
  assignedBy User   @relation("AssignedBy", fields: [assignedById], references: [id], onDelete: Cascade)

  @@unique([lessonId, studentId])
  @@index([assignedById])
}

model Achievement {
  id          String          @id @default(cuid())
  userId      String
  type        AchievementType
  name        String
  description String
  metadata    Json?
  awardedAt   DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, awardedAt])
}

model XPLog {
  id         String   @id @default(cuid())
  userId     String
  amount     Int
  reason     String
  sourceType String
  sourceId   String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Rubric {
  id           String       @id @default(cuid())
  organization Organization
  eventType    String
  name         String
  version      Int          @default(1)
  description  String       @db.Text
  scoreMin     Int          @default(0)
  scoreMax     Int          @default(100)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  categories RubricCategory[]
  debates    Debate[]

  @@unique([organization, eventType, version])
  @@index([organization, eventType, isActive])
}

model RubricCategory {
  id                  String   @id @default(cuid())
  rubricId            String
  key                 String
  label               String
  description         String   @db.Text
  scoreMin            Int      @default(1)
  scoreMax            Int      @default(5)
  weight              Int      @default(1)
  order               Int      @default(0)
  lessonSlugs         String[] @default([])
  sharedSpeakingSkill Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  rubric      Rubric             @relation(fields: [rubricId], references: [id], onDelete: Cascade)
  descriptors RubricDescriptor[]

  @@unique([rubricId, key])
  @@index([rubricId, order])
}

model RubricDescriptor {
  id          String   @id @default(cuid())
  categoryId  String
  label       String
  minScore    Int
  maxScore    Int
  description String   @db.Text
  createdAt   DateTime @default(now())

  category RubricCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId, minScore, maxScore])
}

model SpeakingSkillSnapshot {
  id              String       @id @default(cuid())
  userId          String
  organization    Organization
  eventType       String
  sourceType      String
  sourceId        String?
  clarity         Int?
  confidence      Int?
  pacing          Int?
  volume          Int?
  organizationScore Int?
  vocabulary      Int?
  persuasion      Int?
  professionalism Int?
  createdAt       DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([organization, eventType])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
