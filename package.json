    "next": "14.2.18",
    "next-auth": "^4.24.11",
    "openai": "^4.77.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.24.1"
